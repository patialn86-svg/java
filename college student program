class CollegeStudent {

    private int rollNo;

    public void setRollNo(int rollNo) {
        this.rollNo = rollNo;
    }

    public int getRollNo() {
        return rollNo;
    }

    public static void main(String[] args) {

        CollegeStudent s = new CollegeStudent();

        s.setRollNo(101);

        System.out.println("Roll Number: " + s.getRollNo());
    }
}